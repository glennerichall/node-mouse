# Port d'ecoute du serveur HTTP/HTTPS
PORT=3000

# Host/IP a afficher dans l'URL/QR (laisser vide pour auto-detection LAN)
SERVER_HOST=

# Sensibilite du deplacement souris
MOUSE_SPEED=1.3

# Sensibilite du scroll
SCROLL_SPEED=0.25

# Activer HTTPS (true/false)
HTTPS=false

# Chemin vers la cle privee PEM (requis si HTTPS=true)
SSL_KEY_PATH=

# Chemin vers le certificat PEM (requis si HTTPS=true)
SSL_CERT_PATH=

# Activer le point d'entree aleatoire (true/false)
ENTRY_PATH_ENABLED=true

# Chemin fixe au lieu d'un token aleatoire (optionnel)
ENTRY_PATH_FIXED=

# Longueur du token aleatoire d'entree
ENTRY_PATH_TOKEN_LENGTH=24

# Rotation automatique du token d'entree (minutes)
ENTRY_PATH_ROTATE_INTERVAL_MIN=60

# Duree de validite des anciens tokens (minutes)
ENTRY_PATH_GRACE_MIN=120

# Fichier JSON de persistance du token/rotation (laisser vide = chemin par defaut dans ~/.config)
ENTRY_PATH_STATE_FILE=

# Decalage vertical de l'overlay QR (barre top Ubuntu, etc.)
TOP_BAR_OFFSET_PX=32

# Activer/desactiver l'overlay QR permanent via yad (true/false)
QR_OVERLAY_ENABLED=true

# Taille du QR overlay yad (pixels)
QR_OVERLAY_SIZE=75

# Marge de l'overlay QR par rapport au bord ecran (pixels)
QR_OVERLAY_MARGIN=14

# Largeur de la preview souris (pixels)
PREVIEW_WIDTH=128

# Hauteur de la preview souris (pixels)
PREVIEW_HEIGHT=84

# Frequence de la preview souris (images/seconde)
PREVIEW_FPS=6

# Notifications desktop sur la machine serveur (Windows/Linux/macOS)
DESKTOP_NOTIFICATIONS_ENABLED=true

# Notifications toast envoyees aux clients connectes
CLIENT_NOTIFICATIONS_ENABLED=true

# Duree d'affichage des notifications (millisecondes)
NOTIFICATION_TTL_MS=2200

# Autoriser les actions admin declenchees depuis le client
ADMIN_ACTIONS_ENABLED=true

# Nom du service systemd --user a redemarrer
SERVICE_NAME=remote-mouse.service

# Activer la verification periodique d'une nouvelle version
UPDATE_CHECK_ENABLED=false

# Source de verification: auto | npm | git
UPDATE_CHECK_SOURCE=auto

# Intervalle de verification des mises a jour (minutes)
UPDATE_CHECK_INTERVAL_MIN=360

# Package npm a verifier (laisser vide pour utiliser le nom du package local)
UPDATE_CHECK_PACKAGE=

# Version courante forcee (laisser vide pour utiliser package.json)
UPDATE_CHECK_CURRENT_VERSION=

# Remote git a verifier (si source git/auto)
UPDATE_CHECK_GIT_REMOTE=origin

# Ref git a verifier (si source git/auto), ex: HEAD, refs/heads/main
UPDATE_CHECK_GIT_REF=HEAD

# Commande shell pour installer une mise a jour (optionnel)
# Si vide: fallback auto vers "npm update -g <UPDATE_CHECK_PACKAGE> --force"
UPDATE_INSTALL_COMMAND=

# Timeout max de la commande d'installation (secondes)
UPDATE_INSTALL_TIMEOUT_SEC=600
