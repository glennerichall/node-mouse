# HTTP/HTTPS server listen port
PORT=3000

# Host/IP to display in the URL/QR code (leave empty for LAN auto-detection)
SERVER_HOST=

# Main configuration directory (env + sqlite)
CONFIG_DIR=~/.config/remote-mouse

# Full or relative path to the persistence SQLite file
PERSISTENCE_DB_PATH=~/.config/remote-mouse/remote-mouse.sqlite3

# Explicit environment file path (optional)
# If empty, the server looks for CONFIG_DIR/.env first
ENV_FILE_PATH=


# Enable HTTPS (true/false)
HTTPS=false

# Path to the PEM private key (required if HTTPS=true)
SSL_KEY_PATH=

# Path to the PEM certificate (required if HTTPS=true)
SSL_CERT_PATH=

# Enable the random entry path (true/false)
ENTRY_PATH_ENABLED=true

# Fixed path instead of a random token (optional)
ENTRY_PATH_FIXED=

# Random entry token length
ENTRY_PATH_TOKEN_LENGTH=24

# Automatic entry token rotation interval (minutes)
ENTRY_PATH_ROTATE_INTERVAL_MIN=60

# Grace period for previous tokens (minutes)
ENTRY_PATH_GRACE_MIN=120

# Session cookie name (used for HTTP + WebSocket)
SESSION_COOKIE_NAME=remote_mouse_session

# Cookie signing secret (MUST be changed in production)
SESSION_COOKIE_SECRET=change-me

# Session cookie lifetime (days)
SESSION_COOKIE_MAX_AGE_DAYS=7

# Maximum accepted age for a client-to-server Socket.IO event (ms)
SOCKET_EVENT_MAX_AGE_MS=1200

# Server log verbosity: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Server log format: json, pretty, flat
LOG_FORMAT=json

# Allow admin actions triggered from the client
ADMIN_ACTIONS_ENABLED=true

# Name of the systemd --user service to restart
SERVICE_NAME=remote-mouse.service

# Optional custom shell command used to restart the local service/daemon
# If set, it takes precedence over the platform-specific restart strategy
SERVICE_RESTART_COMMAND=

# Update check shell command (optional, takes precedence)
# Supported protocols:
# - JSON: {"hasUpdate":true,"key":"...","title":"...","message":"...","ttlMs":8000}
# - Text: "1"/"true"/"update" => update detected; "0"/"false"/"none" => no update
UPDATE_CHECK_COMMAND=

# Maximum timeout for the update check command (seconds)
UPDATE_CHECK_TIMEOUT_SEC=20

# Update check interval (minutes)
UPDATE_CHECK_INTERVAL_MIN=360

# npm package to check (leave empty to use the local package name)
UPDATE_CHECK_PACKAGE=

# Forced current version (leave empty to use package.json)
UPDATE_CHECK_CURRENT_VERSION=

# Shell command to install an update (optional)
# If empty: automatic fallback to "npm update -g <UPDATE_CHECK_PACKAGE> --force"
UPDATE_INSTALL_COMMAND=

# Maximum timeout for the install command (seconds)
UPDATE_INSTALL_TIMEOUT_SEC=600
